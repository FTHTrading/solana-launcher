# =============================================
# SOLANA LAUNCHER - ENVIRONMENT VARIABLES
# =============================================
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to version control.

# ----- Solana Network -----
# Options: "devnet" | "mainnet-beta" | "testnet"
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Custom RPC endpoint (optional but recommended for production)
# Devnet: https://api.devnet.solana.com
# Mainnet: Obtain from Helius, QuickNode, Alchemy, or similar
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# ----- Platform Fee Config -----
# Treasury wallet that receives platform fees (base58 public key)
# This wallet is also used to gate the /admin dashboard — only this wallet can access it
NEXT_PUBLIC_TREASURY_WALLET=YOUR_TREASURY_WALLET_PUBKEY_HERE

# Platform fee in SOL (e.g., 0.1 = 0.1 SOL)
NEXT_PUBLIC_CREATION_FEE_SOL=0.1

# ----- Metadata Storage Provider -----
# Options: "pinata" | "nft-storage" | "web3-storage"
NEXT_PUBLIC_STORAGE_PROVIDER=pinata

# Pinata (https://pinata.cloud)
PINATA_JWT=YOUR_PINATA_JWT_HERE
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# NFT.Storage (https://nft.storage) - alternative provider
# NFT_STORAGE_TOKEN=YOUR_NFT_STORAGE_TOKEN_HERE

# ----- App Config -----
NEXT_PUBLIC_APP_NAME="Solana Launcher"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Analytics (optional) -----
# PostHog self-hosted or cloud
# NEXT_PUBLIC_POSTHOG_KEY=YOUR_POSTHOG_KEY
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Mixpanel
# NEXT_PUBLIC_MIXPANEL_TOKEN=YOUR_MIXPANEL_TOKEN

# ----- Database (optional, for launch history + analytics) -----
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# DIRECT_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE  # for Supabase

# ----- Admin -----
# Secret for admin API routes (generate with: openssl rand -base64 32)
# ADMIN_API_SECRET=YOUR_ADMIN_SECRET_HERE
